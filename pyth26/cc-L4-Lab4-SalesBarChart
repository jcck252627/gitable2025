
# Validate if input is whole/ positive number for number of stores
def get_validated_num():
    while True:
        num = input("Please enter NUMBER OF STORES (whole number only):   ")
        if num.isdigit() and int(num) > 0:
            return int(num)
        print("Invalid input, You must enter a positive, whole for this input !! Please Try Again ......")

# Validate if input is whole/ positive number and in a multiple of 100 for sales number 
def get_validated_sale100(this_store):
    while True:
        num100 = input(f"\nPlease enter today's sales number for store #{this_store} (whole number and in multiple of $100):   ")
        if num100.isdigit() and int(num100) % 100 == 0 and int(num100) > 100:
            return int(num100)
        
        print("Invalid input. Please enter a positive, whole sales number that is in the MULTIPLE OF $100, Please Try again......")

#def add_stars():
#def append_sales():

stores = []
sales = []

n = get_validated_num()

# collecting and validating input
for i in range(1, n + 1):
    store_name = f"Store #{i}"
    stores.append(store_name)
    
    sale_amount = get_validated_sale100(i)
    sales.append(sale_amount)
    # print(f"{store_name} has sales of ${sale_amount:,} today")

# print store names and their individual bar chart
print("\nSALES BAR CHART (Each * = $100)\n")

for i in range(n):              # Outer loop print each indivual store name
    print(f"{stores[i]}: ", end="")
    
    # inner loop appending and printing sales bar chart stars for each individual store
    for s in range(0, sales[i], 100):
        print("*", end="")
    
    print()  # move to next line