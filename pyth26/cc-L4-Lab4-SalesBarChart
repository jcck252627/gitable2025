
# Validate input is whole/ positive number for number of stores
def get_validated_num():
    while True:
        num = input("Please enter NUMBER OF STORES (whole number only):   ")
        if num.isdigit() and int(num) > 0:
            return int(num)
        print("Invalid input. Please enter a positive, whole for NUMBER OF STORES !! Please Try Again ......")

